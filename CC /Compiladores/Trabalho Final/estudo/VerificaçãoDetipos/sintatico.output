Grammar

    0 $accept: programa $end

    1 $@1: ε

    2 programa: cabecalho variaveis $@1 T_INICIO lista_comandos T_FIMPROGRAMA

    3 cabecalho: T_PROGRAMA T_IDENTIFICADOR

    4 variaveis: ε
    5          | declaracao_variaveis

    6 declaracao_variaveis: tipo lista_variaveis declaracao_variaveis
    7                     | tipo lista_variaveis

    8 tipo: T_INTEIRO
    9     | T_LOGICO

   10 lista_variaveis: lista_variaveis T_IDENTIFICADOR
   11                | T_IDENTIFICADOR

   12 lista_comandos: ε
   13               | comando lista_comandos

   14 comando: leitura
   15        | escrita
   16        | repeticao
   17        | selecao
   18        | atribuicao

   19 leitura: T_LEIA T_IDENTIFICADOR

   20 escrita: T_ESCREVA expr

   21 $@2: ε

   22 $@3: ε

   23 repeticao: T_ENQUANTO $@2 expr T_FACA $@3 lista_comandos T_FIMENQUANTO

   24 $@4: ε

   25 $@5: ε

   26 selecao: T_SE expr T_ENTAO $@4 lista_comandos T_SENAO $@5 lista_comandos T_FIMSE

   27 $@6: ε

   28 atribuicao: T_IDENTIFICADOR $@6 T_ATRIBUICAO expr

   29 expr: expr T_SOMA expr
   30     | expr T_SUBTRACAO expr
   31     | expr T_DIVISAO expr
   32     | expr T_MULTIPLICACAO expr
   33     | expr T_MAIOR expr
   34     | expr T_MENOR expr
   35     | expr T_IGUAL expr
   36     | expr T_E expr
   37     | expr T_OU expr
   38     | termo

   39 termo: T_IDENTIFICADOR
   40      | T_NUMERO
   41      | T_V
   42      | T_F
   43      | T_NAO termo
   44      | T_ABRE expr T_FECHA


